{
  "name": "hummingbird",
  "displayName": "Hummingbird",
  "description": "Hummingbird extension",
  "version": "0.1.0-next",
  "icon": "icon.png",
  "publisher": "redhat",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "podman-desktop": ">=1.25.0"
  },
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "watch": "vite --mode development build -w"
  },
  "contributes": {
    "menus": {
      "dashboard/image": [
        {
          "command": "hummingbird:image-scan",
          "title": "Hummingbird: scan"
        }
      ]
    },
    "commands": [
      {
        "command": "hummingbird:image-scan",
        "title": "Hummingbird: scan",
        "hidden": true
      }
    ],
    "views": {
      "badges/image": [
        {
          "when": "io.hummingbird-project.repository in imageLabelKeys",
          "badge": {
            "label": "hummingbird",
            "color": {
              "dark": "#7dd3fc",
              "light": "#7dd3fc"
            }
          }
        }
      ]
    }
  },
  "devDependencies": {
    "@podman-desktop/extension-hummingbird-core-api": "workspace:^",
    "@podman-desktop/api": "^1.26.1",    "@podman-desktop/grype-extension-api": "next",
    "@types/node": "^24",
    "vite": "^8.0.5",
    "vitest": "^4.0.16",
    "swagger-typescript-api": "^13.6.7"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
